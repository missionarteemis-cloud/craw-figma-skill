{
  "drs-lab": {
    "$description": "DR's Lab — project-specific overrides for the Craw Design System.",
    "$extensions": {
      "craw-design-system": {
        "extends": "../design-tokens.json"
      }
    }
  },

  "color": {
    "bg":          { "$value": "#0A0F18", "$type": "color", "$description": "Deep navy-black background" },
    "bg-surface":  { "$value": "#10151E", "$type": "color", "$description": "Card/surface background" },
    "border":      { "$value": "#1A2030", "$type": "color", "$description": "Subtle borders" },
    "accent":      { "$value": "#247DFF", "$type": "color", "$description": "Primary accent blue" },
    "accent-dim":  { "$value": "#1459CC", "$type": "color" },
    "accent-glow": { "$value": "#247DFF26", "$type": "color", "$description": "Glow/backdrop accent" },
    "green":       { "$value": "#3DBA6E", "$type": "color", "$description": "Success/positive" },
    "text":        { "$value": "#E8EEF5", "$type": "color", "$description": "Primary text on dark" },
    "text-muted":  { "$value": "#5A6478", "$type": "color", "$description": "Secondary text" }
  },

  "typography": {
    "font-family": {
      "display":  { "$value": "'Saint', serif", "$type": "fontFamily", "$description": "Editorial display font" },
      "heading":  { "$value": "'FreeFat', sans-serif", "$type": "fontFamily", "$description": "Bold emphatic headings" },
      "ui":       { "$value": "'LoRes9PlusOTNarrow', monospace", "$type": "fontFamily", "$description": "UI labels/retro text" },
      "mono":     { "$value": "'LoRes9PlusOTNarrow', monospace", "$type": "fontFamily" }
    }
  },

  "spacing": {
    "section": { "$value": "80px", "$type": "dimension", "$description": "DR's Lab uses more breathing room" }
  }
}
